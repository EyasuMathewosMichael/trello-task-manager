{
  "name": "trello-task-manager-server",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js/Express backend for the Trello-like Task Manager",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --testEnvironment node",
    "test:coverage": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --testEnvironment node --coverage"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "cloudinary": "2.10.0",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-validator": "7.3.2",
    "helmet": "8.1.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.1",
    "morgan": "1.10.1",
    "multer": "2.1.1",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.7",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "@jest/globals": "30.3.0",
    "@jest/test-sequencer": "30.3.0",
    "fast-check": "4.7.0",
    "jest": "30.3.0",
    "mongodb-memory-server": "11.1.0",
    "nodemon": "3.1.14",
    "supertest": "7.2.2"
  }
}
