{
  "name": "trello-task-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Advanced Trello-like Task Manager — monorepo",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "test:e2e": "npm run test:e2e --workspace=client",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "10.2.1",
    "prettier": "3.8.3"
  }
}
